generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  telegramId  String?  @unique
  name        String?
  lastDraftTo         String?
  lastDraftSubject    String?
  lastDraftBody       String?
  lastDraftContactId  String?  // GHL contact_id if replying via GHL
  lastDraftChannel    String?  // "gmail" | "ghl_email" | "ghl_sms"
  lastPipeline        String?  // JSON array of last pipeline results shown
  preferences         String?  // JSON array of learned user preferences
  tasks       Task[]
  ideas       Idea[]
  messages    Message[]
  createdAt   DateTime @default(now())
}

model Task {
  id           String   @id @default(uuid())
  title        String
  description  String?
  status       String   @default("TODO") // TODO, IN_PROGRESS, AGENT_WORKING, DONE, BACKLOG
  priority     String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  category     String   @default("PERSONAL") // PERSONAL, BUSINESS, IDEA
  dueDate      DateTime?
  reminderAt   DateTime?
  result       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(uuid())
  role      String   // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Idea {
  id           String   @id @default(uuid())
  title        String
  description  String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
